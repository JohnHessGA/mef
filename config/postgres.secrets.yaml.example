# PostgreSQL connection configuration for MEF.
#
# Copy this file to config/postgres.secrets.yaml (gitignored) and fill
# in real passwords. The application_name strings make connections
# identifiable in pg_stat_activity.

mefdb:
  host: localhost
  port: 5432
  database: mefdb
  user: mef_user
  password: CHANGEME
  schema: mef
  connect_timeout: 10
  application_name: mef-mefdb

shdb:
  host: localhost
  port: 5432
  database: shdb
  user: mef_user
  password: CHANGEME
  # No schema pinned — MEF reads from both shdb.mart and shdb.shdb.
  connect_timeout: 10
  application_name: mef-shdb

overwatch:
  host: localhost
  port: 5432
  database: overwatch
  user: mef_user
  password: CHANGEME
  schema: ow
  connect_timeout: 10
  application_name: mef-ow
